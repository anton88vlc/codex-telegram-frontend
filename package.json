{
  "name": "codex-telegram-frontend",
  "version": "0.1.0",
  "description": "Telegram remote frontend for Codex Desktop projects and threads.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node bridge.mjs",
    "once": "node bridge.mjs --once",
    "self-check": "node bridge.mjs --self-check",
    "test": "node --test",
    "check": "npm run test && npm run check:python && npm run check:launchd",
    "check:python": "python3 -m py_compile admin/telegram_user_admin.py",
    "check:launchd": "sh -n ops/install-launchd.sh && ./ops/install-launchd.sh --dry-run > /tmp/codex-telegram-bridge.plist && plutil -lint /tmp/codex-telegram-bridge.plist",
    "state:doctor": "node scripts/state_doctor.mjs",
    "onboard:prepare": "node scripts/onboard.mjs prepare",
    "onboard:doctor": "node scripts/onboard.mjs doctor",
    "onboard:scan": "node scripts/onboard.mjs scan",
    "onboard:plan": "node scripts/onboard.mjs plan",
    "onboard:rehearsal": "node scripts/onboard.mjs plan --rehearsal",
    "onboard:wizard": "node scripts/onboard.mjs wizard",
    "onboard:wizard:rehearsal": "node scripts/onboard.mjs wizard --rehearsal",
    "bot:polish": "node scripts/configure_bot_profile.mjs",
    "bot:avatar": "admin/.venv/bin/python admin/telegram_user_admin.py set-bot-avatar",
    "app-server:probe": "node scripts/probe_app_server_stream.mjs",
    "codex:launch": "node scripts/launch_codex_app_control.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
